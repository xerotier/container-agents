# SPDX-License-Identifier: MIT
# Xerotier vLLM Wrapper (macOS / Apple Silicon)
#
# Applies pre-launch configuration before vLLM starts, then invokes
# vLLM normally. The shebang is rewritten by xim-metalctl.sh to point at
# the absolute vllm-metal venv interpreter (~/.venv-vllm-metal/bin/python3).
#
# Patches applied here (API server process only):
#   1. HuggingFace Hub: offline mode + local path safetensors fix

import os
import sys
import warnings

# Suppress SyntaxWarning for invalid escape sequences in vLLM source.
warnings.filterwarnings(
    "ignore",
    message=r"invalid escape sequence",
    category=SyntaxWarning,
)
warnings.filterwarnings(
    "ignore",
    message=r"invalid escape sequence",
    category=DeprecationWarning,
)

# ---------------------------------------------------------------------------
# Patch 1: HuggingFace Hub
# ---------------------------------------------------------------------------

# Force fully offline mode via environment before any HuggingFace imports.
os.environ.setdefault("HF_HUB_OFFLINE", "1")
os.environ.setdefault("TRANSFORMERS_OFFLINE", "1")
os.environ.setdefault("HF_HUB_DISABLE_TELEMETRY", "1")

# Note: The importlib.metadata.version() patch for huggingface_hub
# compatibility is handled globally by xerotier_hf_compat.pth, installed into
# the venv site-packages by xim-metalctl.sh, which applies to ALL Python
# processes (including vLLM subprocesses).

try:
    import huggingface_hub
    _original_get_safetensors_metadata = huggingface_hub.get_safetensors_metadata

    def _local_aware_get_safetensors_metadata(repo_id, *args, **kwargs):
        """Return None for local model paths to skip Hub metadata fetch."""
        if isinstance(repo_id, str) and os.path.isdir(repo_id):
            return None
        return _original_get_safetensors_metadata(repo_id, *args, **kwargs)

    huggingface_hub.get_safetensors_metadata = _local_aware_get_safetensors_metadata
except (ImportError, AttributeError):
    pass


from vllm.entrypoints.cli.main import main


if __name__ == "__main__":
    sys.exit(main())
